{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyctus-core",
  "version": "0.1.0",
  "identifier": "io.nyctus.core",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyctus-core",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "nyc"
        ],
        "name": "Nyctus Project"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}